<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_light">

    <!-- Compact Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/rounded_white_card"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/brand_primary" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_logo"
            app:tint="@color/brand_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="TinyTone"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-rounded"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/scoreCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/star_yellow"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-rounded"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="⭐ 0"
                android:textColor="@color/deep_indigo"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Word Display Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/wordCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/bg_card"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/controls"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Category chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/categoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/magic_mint"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="🎯 All Words"
                    android:textColor="@color/teal_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.4"
                android:fontFamily="sans-serif-rounded"
                android:letterSpacing="0.1"
                android:text="SAY THIS WORD"
                android:textColor="@color/text_title"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- TARGET WORD: includeFontPadding=false fixes clipping for Hard words -->
            <TextView
                android:id="@+id/tvTargetWord"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="12sp"
                app:autoSizeMaxTextSize="38sp"
                app:autoSizeStepGranularity="1sp"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:text="APPLE"
                android:textColor="@color/brand_primary"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivMascotIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginVertical="4dp"
                android:src="@drawable/ic_logo"
                app:tint="@color/brand_secondary"
                android:alpha="0.4"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardBackgroundColor="#F8F5FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E8E0FC"
                app:strokeWidth="1dp">
                <com.example.tinytone.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnListen"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:backgroundTint="@color/sky_blue"
                app:cornerRadius="36dp"
                app:icon="@android:drawable/ic_lock_silent_mode_off"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp"
                app:iconTint="@color/white"
                app:elevation="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="HEAR"
                android:textColor="@color/text_body"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="32dp" android:layout_height="1dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                style="@style/Widget.Material3.Button"
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:backgroundTint="@color/coral"
                app:cornerRadius="48dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="36dp"
                app:elevation="10dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="TALK"
                android:textColor="@color/coral"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="32dp" android:layout_height="1dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:backgroundTint="@color/text_hint"
                app:cornerRadius="36dp"
                app:icon="@android:drawable/ic_media_next"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="@color/white"
                app:elevation="4dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="SKIP"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
