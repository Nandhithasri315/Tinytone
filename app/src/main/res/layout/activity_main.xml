<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_light">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rounded_white_card"
            android:padding="12dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/brand_primary"
            android:contentDescription="Go Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Practice"
            android:textColor="@color/text_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-rounded"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/scoreCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/star_yellow"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-rounded"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="⭐ 0"
                android:textColor="@color/deep_indigo"
                android:textSize="16sp"
                android:textStyle="bold"
                android:contentDescription="Current Stars"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Word Display Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/wordCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/bg_card"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/controls"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Category chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/categoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="🎯 All Words"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.4"
                android:fontFamily="sans-serif-rounded"
                android:letterSpacing="0.2"
                android:text="SAY THIS WORD"
                android:textColor="@color/text_title"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTargetWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:fontFamily="sans-serif-black"
                android:text="APPLE"
                android:textColor="@color/brand_primary"
                android:textSize="64sp"
                android:textStyle="bold" />

            <!-- Mascot Emoji -->
            <TextView
                android:id="@+id/tvMascot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🐘"
                android:textSize="28sp"
                android:alpha="0.7"/>

            <!-- Waveform Panel -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#F8F5FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E8E0FC"
                app:strokeWidth="1dp">

                <com.example.tinytone.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="8dp"
                    android:contentDescription="Voice visualization"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="20dp"
        android:paddingBottom="24dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Listen Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnListen"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:backgroundTint="@color/sky_blue"
                app:cornerRadius="40dp"
                app:icon="@android:drawable/ic_lock_silent_mode_off"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="32dp"
                app:iconTint="@color/white"
                app:elevation="8dp"
                android:contentDescription="Listen to the word"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-rounded"
                android:text="LISTEN"
                android:textColor="@color/text_body"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="40dp" android:layout_height="1dp"/>

        <!-- Skip Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:backgroundTint="@color/text_hint"
                app:cornerRadius="40dp"
                app:icon="@android:drawable/ic_media_next"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp"
                app:iconTint="@color/white"
                app:elevation="4dp"
                android:contentDescription="Skip this word"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-rounded"
                android:text="SKIP"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="40dp" android:layout_height="1dp"/>

        <!-- Record Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                style="@style/Widget.Material3.Button"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:backgroundTint="@color/coral"
                app:cornerRadius="50dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="40dp"
                app:elevation="12dp"
                android:contentDescription="Hold to Speak"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-rounded"
                android:text="SPEAK"
                android:textColor="@color/coral"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
