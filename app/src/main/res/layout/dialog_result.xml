<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="36dp"
    app:cardElevation="24dp"
    app:cardBackgroundColor="@color/bg_card"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Result Header -->
        <TextView
            android:id="@+id/tvResultEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="GREAT JOB!"
            android:textColor="@color/brand_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Accuracy Score -->
        <TextView
            android:id="@+id/tvAccuracyPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-black"
            android:text="0%"
            android:textColor="@color/brand_primary"
            android:textSize="64sp"
            android:textStyle="bold" />

        <!-- Progress Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0ECFF"
            app:strokeWidth="0dp">
            <ProgressBar
                android:id="@+id/accuracyBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/brand_primary"
                android:progressBackgroundTint="#F0ECFF" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Result Message -->
        <TextView
            android:id="@+id/tvResultMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-rounded"
            android:gravity="center"
            android:textColor="@color/text_body"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStarMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-rounded"
            android:paddingHorizontal="20dp"
            android:paddingVertical="6dp"
            android:text="⭐ Star Earned!"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_white_card"
            android:backgroundTint="#FFF9C4"/>

        <!-- Tip Panel -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#E8F5E9"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:text="💡"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvHint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-rounded"
                    android:textColor="#2E7D32"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Details Toggle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalysis"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEE DETAILS"
            android:textColor="@color/brand_primary"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/analysisPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/rounded_white_card"
            android:backgroundTint="#F5F0FF"
            android:padding="12dp">

            <TextView android:id="@+id/tvHeard" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#455A64"/>
            <TextView android:id="@+id/tvVolume" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#455A64"/>
            <TextView android:id="@+id/tvDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#455A64"/>
        </LinearLayout>

        <!-- Continue Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="sans-serif-rounded"
            android:text="CONTINUE  ›"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="20dp"
            app:elevation="8dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
